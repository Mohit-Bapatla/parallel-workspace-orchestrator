{
  "name": "parallel-workspace-orchestrator",
  "version": "1.0.0",
  "description": "CLI for orchestrating batched parallel coding-agent workspaces with git worktrees, resumable state, logs, and merge/test gating.",
  "type": "module",
  "bin": {
    "awo": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "demo:setup": "tsx scripts/create-sample-repo.ts",
    "demo": "npm run demo:setup && tsx src/cli.ts run examples/plan.yaml --repo .demo/sample-repo --agent dry-run --new-run",
    "demo:status": "tsx src/cli.ts status --repo .demo/sample-repo"
  },
  "keywords": [
    "git",
    "worktree",
    "agents",
    "cli",
    "orchestration"
  ],
  "author": "Mohit Bapatla",
  "license": "UNLICENSED",
  "dependencies": {
    "chalk": "^5.0.0",
    "commander": "^14.0.0",
    "execa": "^9.0.0",
    "fs-extra": "^11.0.0",
    "yaml": "^2.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.0",
    "@types/node": "^24.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  }
}
